# Application
APP_NAME="AdMorph Agentic Ads Platform"
DATABASE_URL="sqlite:///./admorph.db"
OUTPUT_DIR="generated"
API_BASE_URL="http://127.0.0.1:8000"

# Generic LLM Configuration
# Options: openai, google, grok, anthropic
LLM_PROVIDER=google
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini-1.5-pro

# Optional: Pixabay API Key for image sourcing  
PIXABAY_API_KEY=your_pixabay_key_here
